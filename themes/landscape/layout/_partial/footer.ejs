<footer id="footer">
  <% if (theme.sidebar === 'bottom'){ %>
    <%- partial('_partial/sidebar') %>
  <% } %>
  <div class="outer">
    <div id="footer-info" class="inner">
      <% if (theme.copyright){ %>
        <%- render(theme.copyright, 'pug'); %>
      <% } %>
      <p>&copy; <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %></p>
      <p class="footer-note">Built with Hexo, curated by hand.</p>
    </div>
  </div>
</footer>
