<section class="home-hero" aria-labelledby="home-hero-title">
  <div class="home-hero-main">
    <% if (theme.home && theme.home.kicker) { %>
      <p class="home-hero-kicker"><%= theme.home.kicker %></p>
    <% } %>
    <h2 id="home-hero-title" class="home-hero-title">
      <%= (theme.home && theme.home.title) || (config.subtitle || config.title) %>
    </h2>
    <p class="home-hero-summary">
      <%= (theme.home && theme.home.summary) || config.description %>
    </p>
    <div class="home-hero-actions">
      <a class="home-hero-action home-hero-action-primary" href="<%- url_for((theme.home && theme.home.primary_link) || '/about') %>">
        <%= (theme.home && theme.home.primary_label) || 'About' %>
      </a>
      <a class="home-hero-action" href="<%- url_for((theme.home && theme.home.secondary_link) || '/archives') %>">
        <%= (theme.home && theme.home.secondary_label) || 'Archives' %>
      </a>
    </div>
  </div>
  <aside class="home-hero-profile" aria-label="Author profile">
    <div class="home-hero-avatar"><%= (config.author || 'L')[0].toUpperCase() %></div>
    <h3 class="home-hero-name"><%= config.author || config.title %></h3>
    <% if (theme.profile && theme.profile.role) { %>
      <p class="home-hero-role"><%= theme.profile.role %></p>
    <% } %>
    <ul class="home-hero-meta">
      <% if (theme.profile && theme.profile.focus) { %>
        <li><%= theme.profile.focus %></li>
      <% } %>
      <% if (theme.profile && theme.profile.location) { %>
        <li><%= theme.profile.location %></li>
      <% } %>
      <li><%= site.posts.length %> posts published</li>
    </ul>
    <% if (theme.profile && theme.profile.motto) { %>
      <p class="home-hero-motto"><%= theme.profile.motto %></p>
    <% } %>
  </aside>
</section>
