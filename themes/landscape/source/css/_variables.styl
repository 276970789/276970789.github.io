// Config
support-for-ie = false
vendor-prefixes = webkit moz ms official

// ===== Legacy Stylus variables (kept for compatibility) =====
// Warm amber accent: oklch(62% 0.15 65) ≈ #c28a2d
color-default = #1f1d17
color-grey = #857f70
color-border = #e5e1d8
color-link = #1f1d17
color-background = #f9f7f3
color-sidebar-text = #857f70
color-widget-background = #f0ece3
color-widget-border = #e5e1d8
color-footer-background = #171510
color-mobile-nav-background = #171510
color-twitter = #00aced
color-facebook = #3b5998
color-pinterest = #cb2027
color-linkedin = #0077B5

// Fonts
font-sans = -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Source Han Sans SC", "Noto Sans SC", "Helvetica Neue", Arial, sans-serif
font-serif = "Instrument Serif", "Noto Serif SC", Georgia, serif
font-mono = "JetBrains Mono", "Fira Code", "Source Code Pro", Consolas, Monaco, monospace
font-icon = ForkAwesome
font-size = 16px
line-height = 1.8em
line-height-title = 1.2em

// Header - compact (no banner)
logo-size = 20px
subtitle-size = 14px
banner-height = 0px
banner-url = hexo-config("banner")

sidebar = hexo-config("sidebar")

// Layout - full-width reading layout
block-margin = 56px
article-padding = 0px
mobile-nav-width = 280px
main-column = 12
sidebar-column = 0

if sidebar and sidebar isnt bottom
  _sidebar-column = sidebar-column
else
  _sidebar-column = 0

// Grids
column-width = 80px
gutter-width = 20px
columns = main-column + _sidebar-column

// Media queries
mq-mobile = "screen and (max-width: 479px)"
mq-tablet = "screen and (min-width: 480px) and (max-width: 767px)"
mq-normal = "screen and (min-width: 768px)"
