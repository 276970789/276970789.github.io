// These are kept for backwards compatibility with partials that @extend them
// Most styles have been moved to individual partials using CSS custom properties

$block-caption
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 0.08em
  color: var(--color-text-muted)
  margin-bottom: var(--space-4)
  line-height: 1em
  font-weight: 700
  font-size: 0.6875rem
  text-shadow: none

// $block is now a flat surface — no card shadows
$block
  background: var(--color-surface)

$base-style
  h1
    font-size: 1.75em
  h2
    font-size: 1.375em
  h3
    font-size: 1.125em
  h4
    font-size: 1em
  h5
    font-size: 1em
  h6
    font-size: 0.875em
    color: var(--color-text-muted)
  hr
    border: none
    border-top: 1px solid var(--color-border)
    margin: var(--space-7) 0
  strong
    font-weight: 700
  em, cite
    font-style: italic
  sup, sub
    font-size: 0.75em
    line-height: 0
    position: relative
    vertical-align: baseline
  sup
    top: -0.5em
  sub
    bottom: -0.2em
  small
    font-size: 0.85em
  acronym, abbr
    border-bottom: 1px dotted var(--color-border)
  ul, ol, dl
    padding-left: 1.5em
    line-height: 1.8
  ul, ol
    ul, ol
      margin-top: 0
      margin-bottom: 0
  ul
    list-style: disc
  ol
    list-style: decimal
  dt
    font-weight: 700
