@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"

global-reset()

// ===== CSS Custom Properties =====
:root
  // Spacing scale
  --space-1: 4px
  --space-2: 8px
  --space-3: 12px
  --space-4: 16px
  --space-5: 24px
  --space-6: 32px
  --space-7: 48px
  --space-8: 64px
  --space-9: 96px

  // Layout
  --header-height: 60px
  --content-max-width: 980px
  --reading-max-width: 720px
  --site-padding: 24px

  // ===== LIGHT MODE COLORS =====
  // Warm cream paper — not pure white, not cold gray
  --color-bg: oklch(98% 0.008 75)
  --color-surface: oklch(100% 0 0)
  --color-border: oklch(90% 0.006 75)
  --color-border-strong: oklch(80% 0.009 75)

  // Text — warm near-black, never pure #000
  --color-text: oklch(14% 0.012 75)
  --color-text-secondary: oklch(42% 0.013 75)
  --color-text-muted: oklch(60% 0.010 75)

  // Accent — warm amber/ochre (literary, editorial, distinctly not AI-blue)
  --color-accent: oklch(62% 0.15 65)
  --color-accent-dim: oklch(72% 0.12 70)
  --color-accent-subtle: oklch(94% 0.05 75)

  // Links — understated dark, hover reveals accent warmth
  --color-link: oklch(14% 0.012 75)
  --color-link-hover: oklch(62% 0.15 65)
  --color-hover: oklch(95% 0.007 75)

  // Surfaces
  --color-code-bg: oklch(95% 0.008 75)
  --color-footer-bg: oklch(11% 0.01 75)
  --color-header-bg: oklch(98% 0.008 75 / 0.94)

  // Shadows — warm-tinted
  --shadow-sm: 0 1px 2px oklch(50% 0.01 75 / 0.08)
  --shadow-md: 0 2px 10px oklch(50% 0.01 75 / 0.10)

  // Typography
  --font-display: "Instrument Serif", "Noto Serif SC", Georgia, serif
  --font-body: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Source Han Sans SC", "Noto Sans SC", "Helvetica Neue", Arial, sans-serif
  --font-mono: "JetBrains Mono", "Fira Code", "Source Code Pro", Consolas, Monaco, monospace

  // Type scale (rem — respects user browser settings)
  --text-xs: 0.75rem
  --text-sm: 0.8125rem
  --text-base: 1rem
  --text-lg: 1.125rem
  --text-xl: 1.375rem
  --text-2xl: 1.625rem
  --text-3xl: 2rem
  --text-4xl: 2.5rem

  // Line heights
  --leading-tight: 1.2
  --leading-snug: 1.35
  --leading-body: 1.8
  --leading-loose: 2

  // Letter spacing
  --tracking-tight: -0.02em
  --tracking-normal: 0
  --tracking-wide: 0.05em
  --tracking-caps: 0.08em

// ===== DARK MODE =====
@media (prefers-color-scheme: dark)
  :root
    // Warm dark — like ink on aged paper, not cold tech-dark
    --color-bg: oklch(13% 0.010 75)
    --color-surface: oklch(17% 0.010 75)
    --color-border: oklch(26% 0.010 75)
    --color-border-strong: oklch(38% 0.012 75)

    // Text — warm off-white
    --color-text: oklch(92% 0.006 75)
    --color-text-secondary: oklch(68% 0.009 75)
    --color-text-muted: oklch(50% 0.008 75)

    // Accent — brighter amber for dark backgrounds (WCAG contrast maintained)
    --color-accent: oklch(74% 0.14 65)
    --color-accent-dim: oklch(65% 0.12 68)
    --color-accent-subtle: oklch(20% 0.04 75)

    // Links
    --color-link: oklch(88% 0.006 75)
    --color-link-hover: oklch(74% 0.14 65)
    --color-hover: oklch(22% 0.009 75)

    // Surfaces
    --color-code-bg: oklch(19% 0.012 75)
    --color-footer-bg: oklch(8% 0.008 75)
    --color-header-bg: oklch(13% 0.010 75 / 0.94)

    // Shadows — subtle on dark
    --shadow-sm: 0 1px 3px oklch(0% 0 0 / 0.3)
    --shadow-md: 0 2px 12px oklch(0% 0 0 / 0.4)


input, button
  margin: 0
  padding: 0
  &::-moz-focus-inner
    border: 0
    padding: 0

// ===== GLOBAL POLISH =====

// Smooth scroll
html
  scroll-behavior: smooth

html, body, #container
  height: 100%

// Text selection — accent-tinted highlight
::selection
  background: var(--color-accent-subtle)
  color: var(--color-text)

// Focus: only show ring on keyboard navigation, not mouse
:focus
  outline: none

:focus-visible
  outline: 2px solid var(--color-accent)
  outline-offset: 2px
  border-radius: 3px

.skip-link
  position: absolute
  top: var(--space-3)
  left: var(--space-3)
  z-index: 200
  padding: var(--space-2) var(--space-3)
  border-radius: 6px
  background: var(--color-text)
  color: var(--color-bg)
  text-decoration: none
  transform: translateY(-160%)
  transition: transform 0.18s ease-out
  &:focus
    transform: translateY(0)

.visually-hidden
  position: absolute
  width: 1px
  height: 1px
  padding: 0
  margin: -1px
  overflow: hidden
  clip: rect(0, 0, 0, 0)
  white-space: nowrap
  border: 0

// HR
hr
  border: none
  border-top: 1px solid var(--color-border)
  margin: var(--space-7) 0

// Reduced motion
@media (prefers-reduced-motion: reduce)
  *, *::before, *::after
    animation-duration: 0.01ms !important
    animation-iteration-count: 1 !important
    transition-duration: 0.01ms !important
    scroll-behavior: auto !important

body
  background: radial-gradient(circle at 10% 0%, oklch(88% 0.04 75 / 0.42) 0%, transparent 38%), var(--color-bg)
  color: var(--color-text)
  font-family: var(--font-body)
  font-size: var(--text-base)
  line-height: var(--leading-body)
  font-kerning: normal
  font-feature-settings: "kern" 1, "liga" 1
  -webkit-text-size-adjust: 100%
  -webkit-font-smoothing: antialiased
  -moz-osx-font-smoothing: grayscale

// Reading-optimized container
.outer
  max-width: var(--content-max-width)
  margin: 0 auto
  padding: 0 var(--site-padding)
  box-sizing: border-box
  @media (max-width: 479px)
    padding: 0 16px

.inner
  width: 100%

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative

.mobile-nav-on
  overflow: hidden

#wrap
  height: 100%
  width: 100%
  position: absolute
  top: 0
  left: 0
  transition: left 0.2s cubic-bezier(0.4, 0, 0.2, 1)
  z-index: 1
  background: var(--color-bg)
  .mobile-nav-on &
    left: mobile-nav-width

// Full-width main — no sidebar columns
#main
  width: 100%
  padding-top: var(--space-8)
  padding-bottom: var(--space-9)
  position: relative

@import "_extend"
@import "_partial/header"
@import "_partial/home"
@import "_partial/article"
@import "_partial/comment"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"

if sidebar
  @import "_partial/sidebar"

// ===== POLISH OVERRIDES =====

// Article tag chips — more refined than raw "#tag" text
.article-tag-list-link
  display: inline-flex
  align-items: center
  padding: 2px var(--space-2)
  border-radius: 4px
  background: var(--color-code-bg)
  color: var(--color-text-muted)
  font-size: var(--text-xs)
  letter-spacing: 0.01em
  transition: background-color 0.15s, color 0.15s
  &:before
    content: "#"
    margin-right: 1px
    opacity: 0.6
  &:hover
    background: var(--color-accent-subtle)
    color: var(--color-text-secondary)

// Ensure images don't overflow narrow screens
img
  max-width: 100%
  height: auto

// Ensure tables don't cause horizontal scroll on mobile
.article-entry table
  display: block
  overflow-x: auto
  -webkit-overflow-scrolling: touch

// Archive page: label before the list
.archives-wrap:first-child .archive-year-wrap
  margin-top: 0

// Page title for archive/category pages
.page-title
  max-width: var(--reading-max-width)
  font-family: var(--font-display)
  font-size: var(--text-3xl)
  font-weight: 400
  letter-spacing: var(--tracking-tight)
  color: var(--color-text)
  margin-bottom: var(--space-8)
  line-height: var(--leading-tight)

// Comment section spacing
#comments
  max-width: var(--reading-max-width)
  margin-top: var(--space-8)
  padding-top: var(--space-7)
  border-top: 1px solid var(--color-border)
