@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap');

:root {
  --bg-color: #F3F2EE;
  --text-main: #111111;
  --text-muted: #555555;
  --accent: #D96C4A;
  --border-color: rgba(0, 0, 0, 0.1);

  --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  --font-serif: "Playfair Display", "Georgia", "Noto Serif SC", "Songti SC", "STSong", serif;

  --max-width: 800px;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-color);
  color: var(--text-main);
  font-family: var(--font-sans);
  line-height: 1.6;
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

a {
  color: inherit;
  text-decoration: none;
  transition: color 0.2s ease, opacity 0.2s ease;
}

a:hover {
  opacity: 0.7;
}

.container {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 24px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Header */
.site-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32px 0;
  border-bottom: 1px solid var(--border-color);
  margin-bottom: 48px;
}

.site-title {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.site-nav {
  display: flex;
  gap: 32px;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-main);
}

.site-nav a {
  opacity: 0.6;
}

.site-nav a:hover {
  opacity: 1;
}

/* Main */
.site-main {
  flex: 1;
}

/* Hero */
.hero {
  padding: 64px 0 120px;
  animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(3.5rem, 9vw, 6.5rem);
  font-weight: 500;
  line-height: 1.05;
  letter-spacing: -0.04em;
  color: var(--text-main);
  max-width: 14ch;
}

/* Post List */
.post-list {
  display: flex;
  flex-direction: column;
  padding-bottom: 80px;
  animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  opacity: 0;
}

.post-item {
  padding: 48px 0;
  border-top: 1px solid var(--border-color);
}

.post-meta {
  display: flex;
  gap: 16px;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 16px;
}

.post-item .post-title {
  font-family: var(--font-serif);
  font-size: 2.25rem;
  font-weight: 500;
  line-height: 1.15;
  margin-bottom: 16px;
  letter-spacing: -0.02em;
}

.post-item .post-excerpt {
  color: var(--text-muted);
  font-size: 1.125rem;
  line-height: 1.6;
}

.post-tags {
  display: flex;
  gap: 8px;
}

.post-tags a:before {
  content: "#";
}

/* Post Full */
.post-full {
  animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.post-full .post-header {
  margin-bottom: 64px;
  padding-top: 40px;
}

.post-full .post-title {
  font-family: var(--font-serif);
  font-size: clamp(3rem, 6vw, 4.5rem);
  font-weight: 500;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 32px;
}

.post-full .post-meta {
  margin-bottom: 0;
}

.post-content {
  font-size: 1.1875rem;
  line-height: 1.7;
  color: var(--text-main);
  padding-bottom: 80px;
}

.post-content h2 {
  font-family: var(--font-serif);
  font-size: 2.5rem;
  margin: 64px 0 32px;
  font-weight: 500;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.post-content h3 {
  font-family: var(--font-serif);
  font-size: 1.75rem;
  margin: 48px 0 24px;
  font-weight: 500;
  letter-spacing: -0.01em;
}

.post-content p {
  margin-bottom: 24px;
}

.post-content ul, .post-content ol {
  margin-bottom: 24px;
  padding-left: 24px;
}

.post-content li {
  margin-bottom: 8px;
}

.post-content img {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 32px 0;
}

.post-content pre, .post-content code {
  background: #F0EFEA;
  border-radius: 4px;
  font-family: monospace;
  font-size: 0.9em;
}

.post-content pre {
  padding: 16px;
  overflow-x: auto;
  margin-bottom: 24px;
}

/* Pagination */
.pagination {
  display: flex;
  gap: 16px;
  padding: 40px 0 80px;
  font-size: 0.9rem;
}

.pagination .current {
  font-weight: 500;
  color: var(--text-main);
}

/* Archive */
.archive-header {
  padding: 80px 0 64px;
  animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.page-title {
  font-family: var(--font-serif);
  font-size: clamp(3.5rem, 8vw, 5.5rem);
  font-weight: 500;
  letter-spacing: -0.03em;
  line-height: 1.05;
}

/* Footer */
.site-footer {
  padding: 48px 0;
  border-top: 1px solid var(--border-color);
  color: var(--text-muted);
  font-size: 0.85rem;
  display: flex;
  justify-content: space-between;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}