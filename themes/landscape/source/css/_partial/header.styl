// ===== COMPACT HEADER — no banner =====

#header
  height: var(--header-height)
  border-bottom: 1px solid var(--color-border)
  background: var(--color-header-bg, var(--color-bg))
  backdrop-filter: blur(6px)
  -webkit-backdrop-filter: blur(6px)
  position: sticky
  top: 0
  z-index: 100

#banner
  display: none

#header-outer
  height: 100%
  max-width: var(--content-max-width)
  margin: 0 auto
  padding: 0 var(--site-padding)
  box-sizing: border-box
  display: flex
  align-items: center
  justify-content: space-between

#header-title
  position: static
  height: auto
  margin-top: 0
  flex-shrink: 0

#logo-wrap
  margin: 0

#logo
  font-family: var(--font-display)
  font-size: 1.25rem
  font-weight: 400
  font-style: italic
  color: var(--color-text)
  text-decoration: none
  letter-spacing: var(--tracking-tight)
  text-shadow: none

#subtitle-wrap
  display: none

#header-inner
  display: flex
  align-items: center
  gap: var(--space-1)
  overflow: visible
  position: static

#main-nav
  display: flex
  align-items: center
  gap: var(--space-1)
  float: none
  margin: 0

.main-nav-link
  color: var(--color-text-secondary)
  font-size: 0.9375rem
  font-weight: 400
  text-decoration: none
  padding: var(--space-2) var(--space-3)
  border-radius: 6px
  transition: color 0.18s ease-out, background-color 0.18s ease-out
  display: flex
  align-items: center
  min-height: 44px
  float: none
  opacity: 1
  text-shadow: none
  letter-spacing: 0
  &:hover
    color: var(--color-text)
    background: var(--color-hover)
  @media mq-mobile
    display: none

.nav-icon
  color: var(--color-text-muted)
  font-size: 14px
  padding: var(--space-2) var(--space-3)
  border-radius: 6px
  display: flex
  align-items: center
  justify-content: center
  min-width: 44px
  min-height: 44px
  text-decoration: none
  transition: color 0.18s ease-out, background-color 0.18s ease-out
  float: none
  opacity: 1
  text-shadow: none
  &:hover
    color: var(--color-text)
    background: var(--color-hover)
    opacity: 1

.nav-button
  border: 0
  background: transparent
  cursor: pointer
  appearance: none

#sub-nav
  display: flex
  align-items: center
  gap: var(--space-1)
  float: none
  margin: 0

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#search-form-wrap
  position: absolute
  top: calc(var(--header-height) + 4px)
  right: var(--site-padding)
  width: 320px
  height: 40px
  opacity: 0
  visibility: hidden
  pointer-events: none
  transform: translateY(-4px)
  transition: opacity 0.15s ease-out, transform 0.15s ease-out, visibility 0s linear 0.15s
  &.on
    opacity: 1
    visibility: visible
    pointer-events: auto
    transform: translateY(0)
    transition-delay: 0s
  @media mq-mobile
    width: calc(100vw - 32px)
    right: 16px

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: var(--color-surface)
  padding: 4px 12px
  border-radius: 8px
  box-shadow: var(--shadow-md)
  border: 1px solid var(--color-border)

.search-form-input
  border: none
  background: none
  color: var(--color-text)
  width: 100%
  font-family: var(--font-body)
  font-size: 0.875rem
  height: 32px
  line-height: 32px

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font-family: font-icon
  font-size: 13px
  border: none
  background: none
  color: var(--color-text-muted)
  cursor: pointer
  &:hover, &:focus
    color: var(--color-text-secondary)
