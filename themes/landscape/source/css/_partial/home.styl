.home-hero
  display: grid
  grid-template-columns: minmax(0, 1fr) 300px
  gap: var(--space-7)
  align-items: start
  padding-bottom: var(--space-8)
  border-bottom: 1px solid var(--color-border)
  margin-bottom: var(--space-8)
  @media (max-width: 900px)
    grid-template-columns: 1fr
    gap: var(--space-5)
  animation: home-rise 360ms cubic-bezier(0.22, 1, 0.36, 1) both

.home-hero-main
  max-width: 720px

.home-hero-kicker
  margin: 0 0 var(--space-3)
  color: var(--color-text-muted)
  letter-spacing: 0.08em
  text-transform: uppercase
  font-size: 0.6875rem
  font-weight: 600

.home-hero-title
  margin: 0
  font-family: var(--font-display)
  font-size: clamp(2.35rem, 5vw, 4rem)
  line-height: var(--leading-tight)
  letter-spacing: var(--tracking-tight)
  font-weight: 400

.home-hero-summary
  margin: var(--space-5) 0 0
  color: var(--color-text-secondary)
  font-size: 1.1875rem
  line-height: 1.8

.home-hero-actions
  margin-top: var(--space-6)
  display: flex
  align-items: center
  gap: var(--space-3)
  flex-wrap: wrap

.home-hero-action
  display: inline-flex
  align-items: center
  justify-content: center
  min-height: 40px
  padding: 0 var(--space-4)
  border-radius: 999px
  border: 1px solid var(--color-border-strong)
  color: var(--color-text-secondary)
  text-decoration: none
  font-size: 0.875rem
  transition: border-color 0.18s ease-out, color 0.18s ease-out, background-color 0.18s ease-out
  &:hover
    border-color: var(--color-accent)
    color: var(--color-text)
    background: var(--color-hover)

.home-hero-action-primary
  background: var(--color-text)
  color: var(--color-bg)
  border-color: var(--color-text)
  &:hover
    background: var(--color-accent)
    border-color: var(--color-accent)
    color: var(--color-bg)

.home-hero-profile
  background: var(--color-surface)
  border: 1px solid var(--color-border)
  border-radius: 14px
  padding: var(--space-6)
  box-shadow: var(--shadow-sm)

.home-hero-avatar
  width: 60px
  height: 60px
  border-radius: 50%
  background: var(--color-accent-subtle)
  color: var(--color-text)
  font-family: var(--font-display)
  font-size: 1.625rem
  display: inline-flex
  align-items: center
  justify-content: center
  margin-bottom: var(--space-4)

.home-hero-name
  margin: 0
  font-size: 1.1875rem
  font-weight: 600
  line-height: 1.35

.home-hero-role
  margin: var(--space-2) 0 0
  color: var(--color-text-secondary)
  font-size: 0.875rem

.home-hero-meta
  margin: var(--space-4) 0 0
  padding: 0
  list-style: none
  display: flex
  flex-direction: column
  gap: var(--space-2)
  color: var(--color-text-muted)
  font-size: 0.8125rem

.home-hero-motto
  margin: var(--space-4) 0 0
  padding-top: var(--space-4)
  border-top: 1px dashed var(--color-border)
  color: var(--color-text-secondary)
  font-size: 0.875rem
  line-height: 1.6

.home-stream
  max-width: var(--reading-max-width)
  animation: home-rise 420ms cubic-bezier(0.22, 1, 0.36, 1) both

@keyframes home-rise
  from
    opacity: 0
    transform: translateY(10px)
  to
    opacity: 1
    transform: translateY(0)

.home-stream-header
  display: flex
  align-items: baseline
  justify-content: space-between
  gap: var(--space-4)
  margin-bottom: var(--space-6)
  h2
    margin: 0
    font-family: var(--font-display)
    font-size: 2rem
    font-weight: 400
    letter-spacing: var(--tracking-tight)
  a
    color: var(--color-text-secondary)
    text-decoration: none
    font-size: 0.875rem
    &:hover
      color: var(--color-link-hover)
  @media mq-mobile
    flex-direction: column
    align-items: flex-start
    margin-bottom: var(--space-5)
